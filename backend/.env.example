# ===================================================================
#  Risk Management System - Backend Environment Variables (TEMPLATE)
#  Copy this file to ".env" and fill in real values.
#    cp .env.example .env      (mac/linux)
#    copy .env.example .env    (windows cmd)
# ===================================================================

# --- DATABASE (MongoDB Atlas) -------------------------------------
# Include the DB name (CustomerReturnRiskAnalyser) before the "?".
ATLAS_URI=mongodb+srv://<username>:<password>@<your-cluster>.mongodb.net/CustomerReturnRiskAnalyser?retryWrites=true&w=majority

# --- SERVER -------------------------------------------------------
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:8080

# --- AUTH / JWT (expiry values are in MILLISECONDS) ---------------
ACCESS_TOKEN_SECRET=replace-with-a-long-random-string
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-string
ACCESS_TOKEN_EXPIRY_MS=900000
REFRESH_TOKEN_EXPIRY_MS=604800000

# --- EMAIL (SendGrid) - optional ----------------------------------
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM=your-verified-sender@example.com
